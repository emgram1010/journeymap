# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: Override the Xano CRUD base URL used by Prototype 2.
VITE_XANO_BASE_URL="https://xdjc-i7zz-jhm2.n7e.xano.io/api:ER4MRRWZ"

# Optional override for the business endpoint used to create a fully-seeded draft map.
# Defaults to: /journey_map/create_draft
VITE_XANO_CREATE_DRAFT_PATH=""

# Optional override for the business endpoint used to load a full map bundle.
# Defaults to: /journey_map/load_bundle/:journeyMapId
VITE_XANO_LOAD_MAP_PATH=""

# Optional override for the business endpoint used to append persisted chat messages.
# Defaults to: /journey_map/:journeyMapId/message
VITE_XANO_MESSAGE_PATH=""

# Optional override for the business endpoint used to persist a single cell edit.
# Defaults to: /journey_cell/update/:journeyCellId
VITE_XANO_UPDATE_CELL_PATH=""

# Optional override for the business endpoint used to rename a stage.
# Defaults to: /journey_stage/rename/:journeyStageId
VITE_XANO_RENAME_STAGE_PATH=""

# Optional override for the business endpoint used to rename a lens.
# Defaults to: /journey_lens/rename/:journeyLensId
VITE_XANO_RENAME_LENS_PATH=""

# Optional overrides for the business endpoints used to add/remove stages and lenses.
VITE_XANO_ADD_STAGE_PATH=""
VITE_XANO_REMOVE_STAGE_PATH=""
VITE_XANO_ADD_LENS_PATH=""
VITE_XANO_REMOVE_LENS_PATH=""
